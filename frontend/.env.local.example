NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GROQ_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to your FastAPI backend URL once deployed (e.g. https://api.yourapp.com)
# Leave empty to keep using the Next.js API routes as fallback
NEXT_PUBLIC_BACKEND_URL=
# Agent service URL (falls back to NEXT_PUBLIC_BACKEND_URL, then Next.js routes)
NEXT_PUBLIC_AGENT_URL=
